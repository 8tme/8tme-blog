---
import { slugify } from '@/utils/content'

interface Props {
  tags: string[]
  category?: string
  class?: string
}

const { tags, category, class: className } = Astro.props
// 统一拼接部署 base，避免 GitHub Pages 子路径下链接 404
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${path.replace(/^\/+/, '')}`
---

<div class="flex flex-wrap gap-2 text-sm text-base/60" class:list={[className]}>
  {
    category && (
      <div>
        <i class="iconfont icon-folder" />
        <a
          class="hover:text-accent hover:underline underline-offset-2 decoration-dashed"
          href={withBase(`/categories/${slugify(category)}`)}
        >
          {category}
        </a>
      </div>
    )
  }
  {
    tags.length > 0 && (
      <div>
        <i class="iconfont icon-hashtag" />
        {tags.map((tag, index) => (
          <>
            {index > 0 && <span>, </span>}
            <a
              class="hover:text-accent hover:underline underline-offset-2 decoration-dashed"
              href={withBase(`/tags/${slugify(tag)}`)}
            >
              {tag}
            </a>
          </>
        ))}
      </div>
    )
  }
</div>
