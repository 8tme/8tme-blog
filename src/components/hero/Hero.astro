---
import { hero, author } from '@/config.json'
import { SocialList } from './SocialList'
import Highlight from '@/components/Highlight.astro'
import HeroBackground from './HeroBackground.astro'

const avatarSrc = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${author.avatar.replace(/^\/+/, '')}`
---

<div class="lg:-mt-16 lg:h-dvh lg:min-h-[720px]">
  <div
    class="relative isolate max-w-[1300px] mx-auto h-full px-4 grid lg:grid-cols-2 items-center justify-items-center"
  >
    <!-- 背景动画层：纯视觉装饰，不参与交互 -->
    <HeroBackground />

    <!-- 左侧文案区 -->
    <div class="mt-[120px] lg:mt-0 max-w-[590px]">
      <h1 class="text-3xl text-center lg:text-left text-balance">
        Hi there, I'm <Highlight class="font-bold">{hero.name}</Highlight>👋<br />{hero.bio}
      </h1>
      <div class="text-sm mt-3 text-center lg:text-left">{hero.description}</div>
      <SocialList className="mt-[60px]" client:load />
    </div>
    <!-- 右侧头像区 -->
    <div class="mt-20 lg:mt-0">
      <div
        class="size-[200px] lg:size-[300px] rounded-full overflow-hidden border border-zinc-200 dark:border-zinc-700 bg-zinc-100 dark:bg-zinc-800"
      >
        <img class="size-full" src={avatarSrc} alt="Site owner avatar" loading="lazy" />
      </div>
    </div>

    <!-- 底部引导区 -->
    <div class="mt-10 lg:mt-0 lg:absolute inset-x-0 bottom-0 flex flex-col items-center">
      <p class="text-xs text-center text-balance">
        {hero.yiyan}
      </p>
      <div class="mt-7 text-xl animate-bounce">
        <i class="iconfont icon-down"></i>
      </div>
    </div>
  </div>
</div>
